# AUR PKGBUILD. Python package (QtWidgets UI) installs under /usr.

pkgname=archhubqt
pkgver=0.1.0
pkgrel=1
pkgdesc="Arch Linux package manager (Qt) with pacman and AUR helper support"
arch=('any')
url="https://github.com/yourusername/ArchHubQt"
license=('GPL3')
depends=('python-pyside6' 'pacman')
optdepends=('paru: AUR support')
makedepends=('python-build' 'python-installer' 'python-wheel' 'python-setuptools')
source=()
sha256sums=()

build() {
  cd "$srcdir/../.."
  python -m build --wheel --no-isolation
}

package() {
  cd "$srcdir/../.."
  python -m installer --destdir="$pkgdir" dist/*.whl
}
